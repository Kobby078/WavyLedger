{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "A business location managed by the user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the shop." },
        "location": { "type": "string", "description": "Physical address or description of location." },
        "baseCurrency": { "type": "string", "description": "The default currency for this shop (e.g., USD, GHS)." },
        "ownerId": { "type": "string", "description": "UID of the user who owns the shop." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "baseCurrency", "ownerId"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the shop inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "costPrice": { "type": "number", "description": "The price the shop paid for the item." },
        "sellingPrice": { "type": "number", "description": "The price the shop sells the item for." },
        "stockQuantity": { "type": "number" },
        "minStockLevel": { "type": "number", "description": "Threshold for low stock alerts." },
        "shopId": { "type": "string" },
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "costPrice", "sellingPrice", "stockQuantity", "shopId", "ownerId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A recorded transaction of goods sold.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "cost": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "totalProfit": { "type": "number" },
        "currency": { "type": "string" },
        "shopId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["date", "items", "totalAmount", "currency", "shopId", "ownerId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenditures.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "currency": { "type": "string" },
        "shopId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["date", "category", "amount", "currency", "shopId", "ownerId"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Tracking money owed to or by the business.",
      "type": "object",
      "properties": {
        "personName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["owe_me", "i_owe"] },
        "status": { "type": "string", "enum": ["pending", "cleared"] },
        "date": { "type": "string", "format": "date-time" },
        "currency": { "type": "string" },
        "shopId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["personName", "amount", "type", "status", "date", "currency", "shopId", "ownerId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastActiveShopId": { "type": "string" }
      },
      "required": ["email"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories for inventory management.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "shopId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "shopId", "ownerId"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Businesses owned by the user."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory items."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense records."
    },
    "/debts/{debtId}": {
      "schema": "Debt",
      "description": "Debt tracking."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Inventory categories."
    }
  }
}
