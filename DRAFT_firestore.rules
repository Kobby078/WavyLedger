rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidShop(data) {
      return data.keys().hasAll(['name', 'baseCurrency', 'ownerId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.baseCurrency is string && data.baseCurrency.size() == 3
        && data.ownerId == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'costPrice', 'sellingPrice', 'stockQuantity', 'shopId', 'ownerId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.costPrice is number && data.costPrice >= 0
        && data.sellingPrice is number && data.sellingPrice >= 0
        && data.stockQuantity is number
        && data.shopId is string && isValidId(data.shopId)
        && data.ownerId == request.auth.uid;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['date', 'items', 'totalAmount', 'totalProfit', 'currency', 'shopId', 'ownerId'])
        && data.date is timestamp
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.totalAmount is number && data.totalAmount >= 0
        && data.currency is string && data.currency.size() == 3
        && data.shopId is string && isValidId(data.shopId)
        && data.ownerId == request.auth.uid;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['date', 'category', 'amount', 'currency', 'shopId', 'ownerId'])
        && data.date is timestamp
        && data.category is string && data.category.size() > 0
        && data.amount is number && data.amount >= 0
        && data.currency is string && data.currency.size() == 3
        && data.shopId is string && isValidId(data.shopId)
        && data.ownerId == request.auth.uid;
    }

    function isValidDebt(data) {
      return data.keys().hasAll(['personName', 'amount', 'type', 'status', 'date', 'currency', 'shopId', 'ownerId'])
        && data.personName is string && data.personName.size() > 0
        && data.amount is number && data.amount >= 0
        && data.type in ['owe_me', 'i_owe']
        && data.status in ['pending', 'cleared']
        && data.date is timestamp
        && data.currency is string && data.currency.size() == 3
        && data.shopId is string && isValidId(data.shopId)
        && data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email'])
        && data.email == request.auth.token.email;
    }

    // --- Collection Matches ---

    match /shops/{shopId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(shopId) && isValidShop(incoming());
      allow update: if isEmailVerified() && isValidShop(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'location', 'baseCurrency'])
        );
      allow delete: if isEmailVerified() && existing().ownerId == request.auth.uid;
    }

    match /products/{productId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isEmailVerified() && isValidProduct(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().shopId == existing().shopId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'costPrice', 'sellingPrice', 'stockQuantity', 'minStockLevel', 'updatedAt'])
        );
      allow delete: if isEmailVerified() && existing().ownerId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(saleId) && isValidSale(incoming());
      // Sales are usually immutable but let's allow totalProfit update if needed or just block update for now
      allow update: if false; 
      allow delete: if isEmailVerified() && existing().ownerId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(expenseId) && isValidExpense(incoming());
      allow update: if isEmailVerified() && isValidExpense(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['category', 'amount', 'description', 'currency', 'date'])
        );
      allow delete: if isEmailVerified() && existing().ownerId == request.auth.uid;
    }

    match /debts/{debtId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(debtId) && isValidDebt(incoming());
      allow update: if isEmailVerified() && isValidDebt(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'status', 'personName', 'dueDate'])
        );
      allow delete: if isEmailVerified() && existing().ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isEmailVerified() && userId == request.auth.uid;
      allow create: if isEmailVerified() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isEmailVerified() && userId == request.auth.uid && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastActiveShopId'])
        );
    }
  }
}
